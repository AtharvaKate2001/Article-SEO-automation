    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const row = item.json;\n  if (row.seo_status === 'pending') {\n    results.push({\n      json: {\n        article_id: row.article_id || \"\",\n        title: row.title || \"\",\n        content: row.content || \"\",\n        category: row.category || \"\",\n        author: row.author || \"\",\n        tags_csv: row.tags_csv || \"\",\n        row_number: row.row_number || \"\",\n        seo_status: \"processing\"\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "e7caf235-6870-4a18-8d4e-73ad5e0d4c80",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  try {\n    const response = items[i].json;\n    const rawContent = response.choices[0].message.content.trim();\n\n    let cleanContent = rawContent;\n    if (cleanContent.startsWith(\"```\")) {\n      const lines = cleanContent.split(\"\\n\");\n      lines.shift();\n      if (lines[lines.length - 1].trim() === \"```\") lines.pop();\n      cleanContent = lines.join(\"\\n\").trim();\n    }\n\n    const seoData = JSON.parse(cleanContent);\n\n    const codeItems = $('Code in JavaScript').all();\n    const articleRow = codeItems[i]?.json || {};\n    const articleId = articleRow.article_id || \"\";\n    const rowNumber = articleRow.row_number || \"\";\n\n    results.push({\n      json: {\n        article_id: articleId,\n        row_number: rowNumber,\n        processed_at: new Date().toISOString(),\n        primary_keywords_csv: (seoData.primary_keywords || []).join(\",\"),\n        long_tail_keywords_csv: (seoData.long_tail_keywords || []).join(\",\"),\n        meta_title: seoData.meta_title || \"\",\n        meta_description: seoData.meta_description || \"\",\n        openai_raw: rawContent,\n        ranking_insights: JSON.stringify(seoData.ranking_insights || {}),\n        seo_status: \"done\"\n      }\n    });\n\n  } catch (e) {\n    const codeItems = $('Code in JavaScript').all();\n    const articleRow = codeItems[i]?.json || {};\n    results.push({\n      json: {\n        article_id: articleRow.article_id || \"\",\n        row_number: articleRow.row_number || \"\",\n        processed_at: new Date().toISOString(),\n        seo_status: \"failed\",\n        seo_error: e.message\n      }\n    });\n  }\n}\n\nreturn results;"
      },
