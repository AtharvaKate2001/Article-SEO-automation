    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst body = item.body || item;\n\nif (!body.title || !body.title.trim()) {\n  throw new Error(\"Validation Error: title is required\");\n}\nif (!body.content || !body.content.trim()) {\n  throw new Error(\"Validation Error: content is required\");\n}\n\nconst tags = Array.isArray(body.tags) \n  ? body.tags.join(',') \n  : (body.tags || '');\n\nconst articleId = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n  const r = Math.random() * 16 | 0;\n  return (c == 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n});\n\nconst createdAt = new Date().toISOString();\n\nreturn [{\n  json: {\n    article_id: articleId,\n    created_at: createdAt,\n    title: body.title.trim(),\n    content: body.content.trim(),\n    category: (body.category || '').trim(),\n    author: (body.author || '').trim(),\n    published_at: (body.published_at || '').trim(),\n    tags_csv: tags,\n    raw_payload: JSON.stringify(body),\n    seo_status: \"pending\",\n    seo_requested_at: createdAt,\n    seo_processed_at: \"\",\n    seo_error: \"\"\n  }\n}];"
